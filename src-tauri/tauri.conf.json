{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bird Brain",
  "version": "0.1.0",
  "identifier": "com.alexander.birdbrain",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": "../app"
    },
    "beforeBuildCommand": {
      "script": "npm run build:sidecar",
      "cwd": "../app"
    },
    "devUrl": "http://localhost:3000",
    "frontendDist": "../app/public"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "bundle/sidecar": "sidecar"
    },
    "copyright": "© 2026 Alexander",
    "category": "DeveloperTool",
    "shortDescription": "Project intelligence console",
    "longDescription": "Bird Brain ingests readable files from a project folder (markdown, text, HTML, SVG, optional source code) into a local hypertext ontology you can explore, synthesize, and query."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
