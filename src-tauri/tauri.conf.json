{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bird Brain",
  "version": "0.1.0",
  "identifier": "com.alexander.birdbrain",
  "build": {
    "beforeDevCommand": "npm --prefix ../app run dev",
    "beforeBuildCommand": "npm --prefix ../app run build:sidecar",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../app/public"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": {
      "../app/.next/standalone": "sidecar"
    },
    "copyright": "© 2026 Alexander",
    "category": "DeveloperTool",
    "shortDescription": "Project intelligence console",
    "longDescription": "Bird Brain turns a folder of markdown into a hypertext ontology you can explore, synthesize, and query."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
